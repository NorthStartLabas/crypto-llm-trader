# ============================================================
# crypto-llm-trader — environment variable template
# Copy this file to .env and replace every 'change_me' value.
# NEVER commit .env to version control.
# ============================================================

# Exchange
EXCHANGE_NAME=kraken

# Safety switch — must stay 'true' until live trading is explicitly approved
DRY_RUN=true

# ------------------------------------------------------------
# Freqtrade env var overrides (FREQTRADE__<section>__<key>)
#
# Freqtrade reads environment variables prefixed with FREQTRADE__
# and uses them to override matching values in the JSON config.
# This keeps secrets out of the config file entirely.
# All values below are picked up automatically via env_file in
# docker-compose.yml and passed into the container.
# ------------------------------------------------------------

# API server credentials (used by FreqUI at http://127.0.0.1:8080)
# Change these before running — defaults in the JSON config are only placeholders.
FREQTRADE__api_server__username=freqtrade
FREQTRADE__api_server__password=change_me
FREQTRADE__api_server__jwt_secret_key=change_me
FREQTRADE__api_server__ws_token=change_me_ws

# Kraken API credentials
# Leave empty for dry-run — public endpoints are used and no key is required.
# Only populate these when deliberately moving to live trading (Phase 4+).
FREQTRADE__exchange__key=
FREQTRADE__exchange__secret=
