# ============================================================
# crypto-llm-trader — environment variable template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# Exchange
EXCHANGE_NAME=kraken

# Kraken API credentials — leave empty for dry-run; add real keys only when intentionally going live
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Safety switch — must stay true until live trading is explicitly approved
DRY_RUN=true

# Freqtrade REST API (used by FreqUI)
FT_API_USERNAME=freqtrade
FT_API_PASSWORD=change_me
FT_JWT_SECRET_KEY=change_me
